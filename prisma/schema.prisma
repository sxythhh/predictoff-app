generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  walletAddress     String    @unique
  username          String?   @unique
  displayName       String?
  avatar            String?
  banner            String?
  bio               String?
  email             String?   @unique
  authProvider      String    @default("wallet")
  oauthId           String?
  embeddedWalletKey String?
  referralCode      String?   @unique
  // Privacy
  profileVisibility String    @default("public") // "public" | "private"
  showBetHistory    Boolean   @default(true)
  showStats         Boolean   @default(true)
  // Tipster
  whopUserId        String?
  whopBusinessId    String?
  whopProductId     String?
  whopPlanId        String?
  isTipster         Boolean   @default(false)
  tipsterBio        String?
  subscriptionPrice Float?    // Monthly price in USD
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  comments           Comment[]
  commentLikes       CommentLike[]
  favorites          Favorite[]
  sessions           Session[]
  activities         Activity[]
  referralsMade      Referral[] @relation("referrer")
  referredBy         Referral?  @relation("referred")
  createdTournaments Tournament[]      @relation("createdTournaments")
  tournamentEntries  TournamentEntry[] @relation("tournamentEntries")
  tipsterPicks       TipsterPick[]          @relation("tipsterPicks")
  subscriptions      TipsterSubscription[]  @relation("tipsterSubscriptions")
  subscribers        TipsterSubscription[]  @relation("tipsterSubscribers")
  following          Follow[]               @relation("following")
  followers          Follow[]               @relation("followers")
  pickLikes          PickLike[]
  pickComments       PickComment[]
  pickTails          PickTail[]

  @@unique([authProvider, oauthId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Comment {
  id        String        @id @default(cuid())
  userId    String
  gameId    String
  content   String
  createdAt DateTime      @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes CommentLike[]

  @@index([gameId, createdAt])
}

model CommentLike {
  id        String @id @default(cuid())
  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  gameId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String   @unique
  referralCode  String
  createdAt     DateTime @default(now())

  referrer User @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referralCode])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "bet_placed" | "bet_won" | "bet_lost" | "comment" | "follow"
  metadata  Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ── Tournament System ──────────────────────────────────────────

model Tournament {
  id                String   @id @default(cuid())
  creatorId         String
  title             String
  description       String?
  format            String   // "profit" | "pickem"
  entryType         String   // "free" | "paid"
  entryFee          Float?
  currency          String?
  prizePool         Float    @default(0)
  prizeStructure    Json?    // { "1": 50, "2": 30, "3": 20 } percentages
  maxParticipants   Int?
  minParticipants   Int      @default(2)
  scoringMethod     String   @default("profit") // "profit" | "roi" | "points"
  scope             String   @default("open")   // "open" | "curated"
  allowedGameIds    Json?    // string[] of Azuro gameIds
  allowedSports     Json?    // string[] of sport slugs
  registrationStart Int      // unix seconds
  registrationEnd   Int
  startsAt          Int
  endsAt            Int
  status            String   @default("draft") // "draft"|"open"|"active"|"scoring"|"completed"|"cancelled"
  visibility        String   @default("public") // "public" | "unlisted" | "private"
  inviteCode        String?  @unique
  flagged           Boolean  @default(false)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  creator      User              @relation("createdTournaments", fields: [creatorId], references: [id], onDelete: Cascade)
  entries      TournamentEntry[]
  games        TournamentGame[]
  picks        TournamentPick[]
  betSnapshots TournamentBetSnapshot[]

  @@index([creatorId])
  @@index([status, startsAt])
  @@index([format, status])
  @@index([inviteCode])
}

model TournamentEntry {
  id            String  @id @default(cuid())
  tournamentId  String
  userId        String
  walletAddress String  // cached for subgraph queries
  score         Float   @default(0)
  rank          Int?
  totalStaked   Float   @default(0)
  totalPayout   Float   @default(0)
  correctPicks  Int     @default(0)
  totalPicks    Int     @default(0)
  entryTxHash   String?
  entryPaid     Boolean @default(false)
  prizeAmount   Float?
  prizeTxHash   String?
  prizePaid     Boolean @default(false)
  joinedAt      DateTime @default(now())

  tournament   Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User                   @relation("tournamentEntries", fields: [userId], references: [id], onDelete: Cascade)
  picks        TournamentPick[]
  betSnapshots TournamentBetSnapshot[]

  @@unique([tournamentId, userId])
  @@index([tournamentId, score])
  @@index([userId])
}

model TournamentGame {
  id           String  @id @default(cuid())
  tournamentId String
  gameId       String  // Azuro gameId
  sportName    String?
  leagueName   String?
  gameTitle    String? // cached: "Team A vs Team B"
  startsAt     Int     // unix seconds
  resolved     Boolean @default(false)
  metadata     Json?   // cached game info

  tournament Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  picks      TournamentPick[]

  @@unique([tournamentId, gameId])
  @@index([tournamentId])
}

model TournamentPick {
  id               String  @id @default(cuid())
  entryId          String
  tournamentId     String
  tournamentGameId String
  conditionId      String
  outcomeId        String
  marketName       String?
  selectionName    String?
  isCorrect        Boolean? // null = pending
  pointsAwarded    Float    @default(0)
  createdAt        DateTime @default(now())

  entry          TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tournament     Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentGame TournamentGame  @relation(fields: [tournamentGameId], references: [id], onDelete: Cascade)

  @@unique([entryId, tournamentGameId, conditionId])
  @@index([tournamentId])
  @@index([entryId])
}

model TournamentBetSnapshot {
  id           String   @id @default(cuid())
  entryId      String
  tournamentId String
  tokenId      String   // Azuro bet tokenId
  gameId       String   // Azuro gameId
  amount       Float
  possibleWin  Float
  odds         Float
  isWin        Boolean?
  isLose       Boolean?
  payout       Float?
  betCreatedAt Int      // unix seconds
  resolvedAt   Int?     // unix seconds
  outcomes     Json     // cached outcome details
  snapshotAt   DateTime @default(now())

  entry      TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tournament Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([entryId, tokenId])
  @@index([tournamentId])
  @@index([entryId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── Pick Engagement ──────────────────────────────────────────────

model PickLike {
  id     String @id @default(cuid())
  userId String
  pickId String

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick TipsterPick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@unique([userId, pickId])
  @@index([pickId])
}

model PickComment {
  id        String   @id @default(cuid())
  userId    String
  pickId    String
  content   String
  createdAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick TipsterPick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@index([pickId, createdAt])
}

model PickTail {
  id        String   @id @default(cuid())
  userId    String
  pickId    String
  createdAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick TipsterPick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@unique([userId, pickId])
  @@index([pickId])
}

// ── Search & Indexing System ──────────────────────────────────────

model IndexedSport {
  id        String   @id @default(cuid())
  sportId   String   @unique          // Azuro sportId
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  teams   IndexedTeam[]
  leagues IndexedLeague[]

  @@index([slug])
}

model IndexedTeam {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?
  sportId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sport     IndexedSport   @relation(fields: [sportId], references: [id])
  homeGames IndexedGame[]  @relation("homeTeam")
  awayGames IndexedGame[]  @relation("awayTeam")

  @@unique([name, sportId])
  @@index([slug])
  @@index([sportId])
  @@index([name])
}

model IndexedLeague {
  id          String   @id @default(cuid())
  slug        String
  name        String
  countrySlug String
  countryName String
  sportId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sport IndexedSport  @relation(fields: [sportId], references: [id])
  games IndexedGame[]

  @@unique([slug, sportId])
  @@index([sportId])
  @@index([countrySlug])
  @@index([name])
}

model IndexedGame {
  id            String   @id @default(cuid())
  azuroGameId   String   @unique
  title         String
  startsAt      Int
  state         String   @default("prematch") // prematch | live | resolved | canceled
  homeTeamId    String
  awayTeamId    String
  leagueId      String
  sportSlug     String
  countrySlug   String
  resolvedAt    Int?
  homeScore     Int?
  awayScore     Int?
  winnerId      String?  // IndexedTeam id, null for draw
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  homeTeam IndexedTeam   @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeam IndexedTeam   @relation("awayTeam", fields: [awayTeamId], references: [id])
  league   IndexedLeague @relation(fields: [leagueId], references: [id])

  @@index([homeTeamId, startsAt])
  @@index([awayTeamId, startsAt])
  @@index([leagueId, startsAt])
  @@index([state, startsAt])
  @@index([sportSlug, startsAt])
  @@index([startsAt])
}

// ── Tipster Picks Marketplace ─────────────────────────────────────

model TipsterPick {
  id            String    @id @default(cuid())
  tipsterId     String
  gameId        String    // Azuro gameId
  gameTitle     String
  sportSlug     String?
  leagueName    String?
  conditionId   String    // Azuro conditionId
  outcomeId     String    // Azuro outcomeId
  marketName    String    // "Match Winner"
  selectionName String    // "Arsenal"
  odds          Float
  confidence    String?   // "high" | "medium" | "low"
  analysis      String?   // Reasoning (max 500 chars)
  startsAt      Int       // Game start time (unix seconds)
  visibility    String    @default("free") // "free" | "premium"
  isResolved    Boolean   @default(false)
  isCorrect     Boolean?  // null=pending, true=hit, false=miss
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  tipster  User        @relation("tipsterPicks", fields: [tipsterId], references: [id], onDelete: Cascade)
  likes    PickLike[]
  comments PickComment[]
  tails    PickTail[]

  @@index([tipsterId, createdAt])
  @@index([gameId])
  @@index([visibility, createdAt])
  @@index([isResolved])
}

model TipsterSubscription {
  id               String    @id @default(cuid())
  subscriberId     String
  tipsterId        String
  whopMembershipId String?
  tier             String    @default("premium") // "premium" | "vip"
  status           String    @default("active")  // "active" | "canceled" | "expired"
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?

  subscriber User @relation("tipsterSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)
  tipster    User @relation("tipsterSubscribers", fields: [tipsterId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, tipsterId])
  @@index([tipsterId, status])
  @@index([subscriberId])
}
